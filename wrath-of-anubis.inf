Constant Story "The Wrath of Anubis";
Constant Headline "^Copyright (c) 2025 Garry Francis^https://bdb-project.itch.io^Type ABOUT for further info and credits.^^";

Array UUID_ARRAY string "UUID://a85babca-6d71-4a11-8c88-4e0d129b8834//";
#Ifdef UUID_ARRAY;
#Endif;

Release 1;
Serial "251009";

!Inform 6 constants
Constant DEATH_MENTION_UNDO;
Constant MAX_CARRIED = 10;
Constant NO_SCORE;

!PunyInform constants
Constant CUSTOM_ABBREVIATIONS;
Constant OPTIONAL_EXTENDED_METAVERBS;
Constant OPTIONAL_EXTENDED_VERBSET;
Constant OPTIONAL_FULL_DIRECTIONS;
Constant OPTIONAL_PRINT_SCENERY_CONTENTS;
Constant OPTIONAL_PROVIDE_UNDO;
Constant RUNTIME_ERRORS 0;!0 for release, 2 for debug

!PunyInform static messages
Constant MSG_COMMENT_NO_TRANSCRIPT "Comment recorded. Use SCRIPT ON to save future comments in a transcript.^";
Constant MSG_COMMENT_TRANSCRIPT "Comment recorded.^";
Constant MSG_FILL_NO_WATER "Fill with what?";
Constant MSG_PARSER_NO_INPUT "You need to enter a command.";
Constant MSG_PARSER_UNKNOWN_VERB "That's not a verb I recognise.";
Constant MSG_SORRY_DEFAULT "Oh, don't apologise.";
Constant MSG_WAIT_DEFAULT "Time passes...";

!PunyInform dynamic messages
Constant MSG_CLOSE_NOT_OPEN 1000;
Constant MSG_LOCK_ALREADY_LOCKED 1001;
Constant MSG_LOCK_CLOSE_FIRST 1002;
Constant MSG_LOCK_KEY_DOESNT_FIT 1003;
Constant MSG_UNLOCK_ALREADY_UNLOCKED 1004;
Constant MSG_UNLOCK_KEY_DOESNT_FIT 1005;

!Game-specific constants
Constant AN "an";
Constant SOME "some";
Constant THE "the";
Constant CANT_GET_PAST_DEBRIS "You can't get past all the debris. You'll need to clear it out of the way.";
Constant CANT_REACH_BECAUSE_OF_SNAKES "You can't reach it because of the snakes.";
Constant CANT_SHOOT_ANYTHING_WITH "You can't shoot anything with ";
Constant CANTEEN_IS_EMPTY "The canteen is empty.";
Constant CUTTING_UP_LIVE_CAMEL_IS_CRUEL "Cutting up the camel while it's still alive would be extremely cruel.";
Constant DESERT_DESCRIPTION "You're surrounded by an immense sea of sand that extends to the horizon, warmed and illuminated by a relentless sun.";
Constant DESERT_HINT "If you're lost in the desert, drop an item to make each location look unique and DRAW A MAP!";
Constant DONT_FIND_ANYTHING_OF_INTEREST ", but don't find anything else of interest.";
Constant FIND_CANTEEN "Find a canteen.";
Constant FIRST_OPENING_CANTEEN "(first opening the canteen)^";
Constant GET_RID_OF_SNAKES_FIRST " You'll have to get rid of the snakes first, or at least clear a path through them.";
Constant HAVE_TO_TELL_ME_WHAT_TO "You'll have to tell me what to ";
Constant ITS_BLOCKED_FROM_OTHER_SIDE ", but it's blocked from the other side";
Constant LID_IS_SEALED_TO_SARCOPHAGUS "You can see that the lid is sealed to the sarcophagus.";
Constant LOOSE_ENOUGH_TO_MOVE "As you've broken the seal between the lid and the sarcophagus, it's now loose enough to move, but too heavy to move by yourself without any leverage.";
Constant NO_WATER_HERE "There's no water here.";
Constant POOR_THING_HAS_BROKEN_LEG "The poor thing has a broken leg and is groaning in agony.";
Constant QUENCH_YOUR_THIRST "Quench your thirst before returning to the desert.";
Constant RAISED_80_MM_ABOVE_FLOOR "raised about 80 mm above the floor.";
Constant REMAINS_OF_ARCHAEOLOGIST " the remains of a poor hapless archaeologist who was less fortunate than yourself.";
Constant SURROUNDED_BY_CRACK "surrounded by a crack";
Constant THIRST_HINT "If you're thirsty, find the oasis to the ";
Constant WELL_NEARBY "There's a well nearby.";
Constant WITH_KNIFE_LODGED_IN_IT " with a knife lodged in it";
Constant YOU_CANT_DRINK_FROM "You can't drink from ";
Constant YOU_DONT_HAVE_FIREARM "You don't have a firearm.";
Constant YOU_EMPTY_CANTEEN "You empty the canteen and the water soaks into the ground. That was probably a silly thing to do.";
Constant YOU_FILL_CANTEEN "You fill the canteen with water.";
Constant YOU_HEAR_RUMBLE_IN_DISTANCE " and you hear a dull rumble in the distance.";

!Replaced actions
Replace _UpdateDarkness;
Replace DrinkSub;
Replace GoSub; !Delete if diagonal directions are used
Replace LockSub;
Replace UnlockSub;

Include "globals.h";

!Game-specific variables

!========================================
! Entry point routines
!========================================
[ InScope person i;
  if (person == player && location == thedark)
    objectloop(i in parent(player))
      if (i has moved)
        PlaceInScope(i);
  rfalse;
];

[ LibraryMessages p_msg p_arg_1 p_arg_2;
  switch (p_msg)
  {
    MSG_CLOSE_NOT_OPEN:
      print_ret (CTheyreOrIts)noun, " already closed.";
    MSG_LOCK_ALREADY_LOCKED:
      print_ret (CTheyreOrIts)noun, " already locked.";
    MSG_LOCK_CLOSE_FIRST:
      "You'll have to close ", (ItOrThem)noun, " first.";
    MSG_LOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoesntOrDont)second, " fit the lock.";
    MSG_UNLOCK_ALREADY_UNLOCKED:
      print_ret (CTheyreOrIts)noun, " already unlocked.";
    MSG_UNLOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoesntOrDont)second, " fit the lock.";
  }
  p_arg_1 = p_arg_2;
];

Include "puny.h";

!========================================
! Initialisation
!========================================
[ Initialise;
  location = room01;
  lookmode = 2;
  no_implicit_actions = true;
  player.description = PlayerDescription;
  "^After a week of studies and conferences in Cairo and three days of fieldwork in the Valley of the Kings, you considered a visit to the remote village of El Rajid as a pleasant and relaxing diversion. Your former Egyptology teacher, Samuel Rahani, had told you about the village. He considered it to be an archaeological gold mine.^^After befriending a local family, you stayed with them for a few days and learned much about the legends of the village. The one that intrigued you the most was told to you by a boy named Simhel.^^Apparently, a young man named Sinuhe was forced to help in the construction of a fabulous pyramid for the pharaoh. Sinuhe hated the pharaoh because of the suffering he inflicted on him and his co-workers, so he decided to kill the pharaoh.^^During the Festival of the Sun, Sinuhe snuck into the pharaoh's palace to kill him, but he was caught by the palace guards and thrown to the crocodiles. This act enraged Anubis, the ancient Egyptian god of mummification and the afterlife.^^Anubis raised the spirit of Sinuhe and sent him to haunt the pharaoh and his descendants for generations to come. It is said that the spirit still haunts all those who live in the valley around El Rajid, descendants of the pharaoh or not.^^This legend is so rooted in the history of the village that every year, on the Festival of the Sun, the villagers leave their homes to search the remains of the ancient pharaoh's palace, hoping to find the medallion that Sinuhe was wearing when he was killed. According to the legend, if the medallion is melted down and transformed into the figure of Anubis, the wrath of Anubis will be appeased and Sinuhe will have a peaceful afterlife.^^The young Simhel also confided a curious detail to you. According to him, the remains of Sinuhe were not to be found in the ruins of the palace, but inside a pyramid that no one has ever found and was thought to have been consumed by the desert sands.^^When you wake on the morning of the Festival of the Sun, you discover that the villagers have already left to search for the medallion of Sinuhe, leaving you alone to follow the leads that Simhel gave you.^";
];

!========================================
! Classes
!========================================
Class OpenableContainer
with
  invent
  [;
    if (inventory_stage == 2 && (self hasnt open || child(self) == 0))
      rtrue;
  ],
has container openable;

Class OpenContainer
with
  invent
  [;
    if (inventory_stage == 2 && child(self) == 0)
      rtrue;
  ],
has container open;

Class Surface
with
  invent
  [;
    if (inventory_stage == 2 && child(self) == 0)
      rtrue;
  ],
has supporter;

!========================================
! Room 1: Small Building
!========================================
Object room01 "Small Building"
with
  description "This narrow building is where you've been staying for the past few days. It could best be described as a combination of a kitchen and a bedroom with very modest furnishings. The building only has one exit to the south. As it's the Festival of the Sun, the family that owns it has gone to look for the medallion of Sinuhe.",
  s_to room02,
  out_to room02,
  before
  [;
    Hint:
      if (chisel in nothing)
        "Examine the table.";
  ],
has light;

!----------------------------------------
! Building (floating object)
!----------------------------------------
Object "building"
with
  name 'building' 'house' 'narrow' 'small' 'kitchen' 'bedroom' 'room',
  description "This building is the house where you've been living during your short stay in El Rajid.",
  before
  [;
    Enter:
      if (self in room02)
        <<Go FAKE_N_OBJ>>;
    Exit:
      if (self in room01)
        <<Go FAKE_S_OBJ>>;
  ],
  found_in room01 room02,
has scenery;

!----------------------------------------
! Furnishings
!----------------------------------------
Object "furnishings" room01
with
  name 'furniture' 'furnishings' 'modest' 'bed',
  description "None of the furnishings here are worth worrying about, except maybe the table.",
has pluralname scenery;

!----------------------------------------
! Table
!----------------------------------------
Object table "table" room01
class Surface
with
  name 'old' 'dark' 'wooden' 'table',
  description
  [;
    print "It's an old dark wooden table used mainly for food preparation. ";
    <<Search self>>;
  ],
  before
  [;
    Search:
      if (chisel in nothing)
        move chisel to self;
  ],
has static supporter;

!----------------------------------------
! Chisel
!----------------------------------------
Object chisel "chisel"
with
  name 'chisel',
  description "It's a specialised tool used for removing layers of earth and rock to uncover artifacts and lifting fragile objects.",
has;

!========================================
! Room 2: Village of El Rajid
!========================================
Object room02 "Village of El Rajid"
with
  description "You're on the road that passes through the small village of El Rajid. It heads east towards the ruins and south towards the desert. A small building to the north is the house of the family where you've been staying.",
  n_to room01,
  s_to room05,
  e_to room03,
  in_to room01,
has light;

!----------------------------------------
! Road
!----------------------------------------
Object "road" room02
with
  name 'road' 'packed' 'earth',
  description "It's a packed earth road that heads east to the palace ruins and south to the desert.",
has scenery;

!----------------------------------------
! Village of El Rajid
!----------------------------------------
Object "village" room02
with
  name 'small' 'village' 'of' 'el' 'rajid',
  description "This is the village of El Rajid. It's hot and dry and dotted with mud-brick dwellings. It's unusually quiet at the moment, as the inhabitants have gone off to look for the medallion of Sinuhe in the palace ruins.",
has scenery;

!----------------------------------------
! Palace ruins (floating object)
!----------------------------------------
Object "ruins"
with
  name 'palace' 'ruins',
  description "The palace ruins are to the east, but you can't see them from here.",
  found_in room02 room03,
has pluralname scenery;

!----------------------------------------
! Desert (floating object)
!----------------------------------------
Object "desert"
with
  name 'desert',
  description "The desert is to the south.",
  found_in room02 room05,
has scenery;

!----------------------------------------
! Sun (floating object)
!----------------------------------------
Object "sun"
with
  article THE,
  name 'sun' 'sunlight',
  description "Don't look at the sun or it will blind you.",
  before
  [;
    if (action ~= ##Examine)
      "The sun is too far away.";
  ],
  found_in
  [;
    if (location has light && location ~= room01 or room10 or room22)
      rtrue;
  ],
has scenery;

!----------------------------------------
! Dwellings
!----------------------------------------
Object "dwellings" room02
with
  name 'mud-brick' 'mud' 'brick' 'dwellings' 'white' 'buildings',
  description "The only dwelling of interest to you is the small building to the north, as this is the one where you've been staying for your short visit to El Rajid.",
has pluralname scenery;

!========================================
! Room 3: Road to Ruins
!========================================
Object room03 "Road to Ruins"
with
  description "You're on the road that leads east to the ruins of the palace where the villagers are looking for the medallion of Sinuhe. The centre of El Rajid is to the west and your Jeep is parked on the side of the road.",
  e_to
  [;
    print_ret (The)man, " says, ~Strangers aren't allowed to enter the ruins.~";
  ],
  w_to room02,
  in_to room04,
  before
  [;
    Hint:
      if (room04 hasnt visited)
        "Make sure you have a look in your Jeep.";
      "Talk to ", (the)man, " and ask him about everything you've learnt and anything he mentions. He's a mine of information.";
  ],
has light;

!----------------------------------------
! Road
!----------------------------------------
Object "road" room03
with
  name 'road',
  description "It's the road from El Rajid to the palace ruins.",
has scenery;

!----------------------------------------
! Jeep (floating object)
!----------------------------------------
Object "Jeep"
with
  article "your",
  name 'willys' 'mb' 'jeep' 'vehicle',
  description "It's a World War II vintage Willys MB Jeep. You hired it from a seedy-looking character in Cairo.",
  before
  [;
    Drive, SwitchOn:
      if (self in room03)
        "You'll need to get in the Jeep first.";
      else
        "You've only got enough fuel to return to Cairo and you need to finish your mission here before you can do that.";
    Enter:
      if (self in room03)
        <<Go FAKE_IN_OBJ>>;
    Exit:
      if (self in room04)
        <<Go FAKE_OUT_OBJ>>;
  ],
  found_in room03 room04,
has scenery;

!----------------------------------------
! Big burly man
!----------------------------------------
Object man "big burly man" room03
with
  name 'big' 'burly' 'hairy' 'man' 'achmed',
  short_name
  [;
    if (self has proper)
    {
      print "Achmed";
      rtrue;
    }
    rfalse;
  ],
  description "He's a big man, very hairy, and not someone to mess with.",
  life
  [;
    Ask:
      wn = consult_from;
      switch (NextWord())
      {
        'achmed':
          "~That's me.~";
        'anubis':
          "~Anubis is the god of the afterlife and the dead. He's commonly depicted as a man with a jackal's head. Anubis also judges the deceased. When he judged the good soul of Sinuhe, he was furious that he had been fed to the crocodiles and not given a proper burial. Or so the legend goes.~";
        'arab', 'arabs', 'bedouin', 'nomad', 'nomads':
          "~There are many nomads in the desert. Most of them are Bedouin Arabs. In fact, some of the people in the village are also Bedouin Arabs, but they are no longer nomadic.~";
        'camel', 'camels':
          "~Camels are known as 'the ships of the desert' because they are the only means of transport in the desert. They're also an important source of meat.~";
        'crocodile', 'crocodiles':
          "~There are no crocodiles in the desert, but there were Nile crocodiles in the days of the pharaohs, before the Nile changed its course further to the east.~";
        'custom', 'customs', 'local', 'tradition', 'traditions':
          "~We have many customs. Today is the Festival of the Sun, where we celebrate Ra, but it's also the one day of the year where we search the ruins of the former pharaoh's palace in search of Sinuhe's medallion.~";
        'desert':
          "~If you want desert, we have plenty of desert. Once you leave the village, there's nothing but desert for miles and miles. Oh, apart from the oasis.~";
        'el', 'rajid', 'village':
          "~El Rajid is our village, but you know that already, as you've been staying with us for the past few days.~";
        'festival', 'sun', 'summer', 'solstice':
          "~The Festival of the Sun is held on the day of the summer solstice. It's a local tradition that's been held for thousands of years to celebrate Ra.~";
        'ghost', 'soul', 'spirit':
          "~The ghost of Sinuhe was meant to haunt the descendents of the pharaoh, but I guess ghosts aren't very choosy, so it just haunts anyone in the village at random.~";
        'god', 'gods':
          "~There are many gods. Which one would you like to know about?~";
        'him', 'himself':
          give self proper;
          "~My name is Achmed.~";
        'legend', 'legends':
          "~Which legend? We have many legends, but the one we're celebrating today is the legend of Sinuhe and his lost medallion.~";
        'me', 'myself', 'self', 'ken', 'richards':
          "~I know only that you are an archaeologist and a visitor to our village. You are most welcome. We ask only that you honour our customs.~";
        'medallion', 'medal':
          "~It is said that Sinuhe was wearing a medallion when he was fed to the crocodiles. If that medallion can be found, it can be melted down and made into a statuette of Anubis to appease his wrath. Only then will Sinuhe's ghost stop haunting us.~";
        'nile', 'river':
          "~The Nile River is the nearest river to here, but it's many miles away to the east.~";
        'oasis', 'oases', 'water':
          "~There's an oasis in the desert to the west. We get our water from there.~";
        'palace', 'ruins':
          "~This was the palace of the pharaoh at the time when Sinuhe was fed to the crocodiles.~";
        'pharaoh':
          "~Which pharaoh? There were many pharaohs, but the one who lived in this palace was said to be a cruel tyrant. You can understand why Sinuhe tried to kill him.~";
        'pyramid':
          "~It is said that the pharaoh's pyramid sunk in the desert. It's never been found.~";
        'ra':
          "~Ra is the god of sun, light and creation. He travels across the sky during the day and descends into the underworld at night. He's depicted in ancient Egyptian paintings as a human with a falcon's head and a solar disk above his head.~";
        'simhel':
          "~Simhel? I don't know any Simhel. Oh, wait, do you mean that mischievous boy in the village? He has a vivid imagination. Don't believe anything he tells you.~";
        'sinuhe':
          "~Sinuhe was the one who tried to kill the pharaoh back in the day when the pharaoh's pyramid was being built, but he was caught and fed to the crocodiles and his ghost still haunts the village.~";
        'sobek':
          "~Sobek is the god of fertility and military prowess. He's often associated with the Nile River and its crocodiles, so he's usually depicted as a human with the head of a crocodile.~";
        'tyrant':
          "~The pharaoh who lived in this palace was said to be a cruel tyrant, but no one remembers his name. It's more likely that no one WANTS to remember his name.~";
        default:
          "~I don't have time to answer questions. I need to help the others with the search.~";
      }
    Attack:
      print_ret (The)self, " is much bigger than you, so don't get any funny ideas.";
    Talk:
      "Despite his appearance, ", (the)self, " seems quite friendly. ~You're welcome to stay in our village, but this is the one day of the year when the locals search for the medallion of Sinuhe. The ruins are dangerous, so strangers aren't allowed to enter. It's for your own safety. I'm sure you understand.~";
    Thank:
      print_ret (The)self, " says, ~You're welcome.~";
  ],
has animate;

!========================================
! Room 4: In Your Jeep
!========================================
Object room04 "In Your Jeep"
with
  description "You're sitting in your Jeep. There's a thick layer of dust covering the interior of the vehicle, but you reckon the dust gives it character. When you've got everything you need, just get out of the Jeep.",
  out_to room03,
  before
  [;
    Hint:
      if (checklist in nothing)
        "Open the book.";
      if (checklist hasnt general)
        "Read the checklist.";
      "Make sure you collect everything on the checklist before venturing into any unknown ruins.";
  ],
has light;

!----------------------------------------
! Dust
!----------------------------------------
Object "dust" room04
with
  article SOME,
  name 'dust' 'thick' 'layer' 'of' 'interior',
  description "Everything out here is dusty, the interior of the Jeep is no exception.",
has scenery;

!----------------------------------------
! Flashlight
!----------------------------------------
Object flashlight "flashlight" room04
with
  name 'flashlight' 'torch' 'ex-military',
  short_name
  [;
    if (self has light)
      print "lit ";
    rfalse;
  ],
  invent
  [;
    if (inventory_stage == 2)
      rtrue;
  ],
  description
  [;
    print "It's an ex-military flashlight that you picked up in an army disposal store in Cairo. It's currently turned ";
    if (self has light)
      "on.";
    else
      "off.";
  ],
  before
  [;
    Burn, SwitchOn:
      if (self has light)
        "It's already on.";
      give self light;
      "You turn the flashlight on.";
    Extinguish, SwitchOff:
      if (self hasnt light)
        "It's already off.";
      give self ~light;
      "You turn the flashlight off.";
  ],
has;

!----------------------------------------
! Book
!----------------------------------------
Object book "book" room04
with
  name 'book' 'volume',
  description
  [;
    print "It's a volume on the translation of ancient Egyptian symbols and writing.";
    if (self hasnt general)
      print " Maybe you should read it to refresh your memory.";
    "";
  ],
  before
  [;
    Close:
      "It's already closed.";
    Open, Read:
      give self general;
      if (checklist notin nothing)
        "You open the book and flick through the pages to refresh your memory, but there's too much to take it all in, so you close it up again.";
      move checklist to location;
      "When you open the book to read it, something falls out.";
  ],
has;

!----------------------------------------
! Checklist
!----------------------------------------
Object checklist "checklist"
with
  name 'checklist' 'list',
  description
  [;
    print "It's a tattered checklist that you always carry with you as a reminder of the essentials you'll need before venturing into unexplored territory.";
    if (self hasnt general)
      print " It wouldn't hurt to read it, just to refresh your memory.";
    "";
  ],
  before
  [;
    Read:
      give self general;
      "It reads,^'My checklist:^- Light source^- Firearm (just in case)^- Chisel^- Knife^- Rations'";
  ],
has;

!----------------------------------------
! Pistol
!----------------------------------------
Object pistol "pistol" room04
with
  name 'pistol' 'colt' 'm1911a1' 'semi-automatic' 'gun' 'firearm',
  description "It's a World War II issue Colt M1911A1 semi-automatic pistol that you picked up in an army disposal store in Cairo.",
has;

!========================================
! Room 5: Road from Village to Desert
!========================================
Object room05 "Road from Village to Desert"
with
  description "You're now on the road that leads from the village to the desert and vice versa. You know that the security of the low white buildings of the village are in the distance to the north, but they're now out of sight, whereas the harsh yellow dunes of the desert are in the opposite direction to the south.",
  n_to room02,
  s_to
  [;
    if (player hasnt general)
    {
      desert.time_left = 20;
      StartDaemon(desert);
    }
    return room06;
  ],
  before
  [;
    Hint:
      if (chisel hasnt moved || flashlight hasnt moved || pistol hasnt moved)
        "Make sure you search the village and collect useful objects before venturing into the desert.";
  ],
has light;

!----------------------------------------
! Road
!----------------------------------------
Object "road" room05
with
  name 'road' 'dry' 'packed' 'soft' 'harsh' 'yellow' 'sand' 'dunes',
  description "The dry packed sand of the road gives way to the soft sand of the dunes to the south.",
has scenery;

!========================================
! Room 6: Desert
!========================================
Object room06 "Desert"
with
  description DESERT_DESCRIPTION,
  n_to
  [;
    if (player hasnt general)
      StopDaemon(desert);
    return room05;
  ],
  s_to room14,
  e_to room16,
  w_to room07,
  before
  [;
    Hint:
      if (player hasnt general)
        print_ret (string)THIRST_HINT, "west.";
      print_ret (string)DESERT_HINT;
  ],
has light;

!----------------------------------------
! Desert (floating object)
!----------------------------------------
Object desert "desert"
with
  article THE,
  name 'desert' 'sea' 'of' 'sand' 'dune' 'dunes' 'horizon',
  description "It's a harsh and unrelenting desert.",
  before
  [;
    Dig:
      "You try digging a hole with your hands, but the dry desert sand just falls back in on itself.";
  ],
  daemon
  [;
    self.time_left--;
    if (self.time_left > 10)
      rtrue;
    if (self.time_left > 4)
      "^You're starting to get thirsty. You won't get very far without water.";
    switch (self.time_left)
    {
      4: "^The desert sun beats down hard and the heat makes your journey more and more tiring.";
      3: "^Your throat is completely dry and your tongue sticks to the roof of your mouth.";
      2: "^A veil begins to fall over your eyes and you feel the blood pulsing in your temples.";
      1: "^You don't even have the strength to scream. If you don't drink some water NOW, you'll pass out in the desert heat.";
      0: deadflag = 1;
         "^The heat overwhelms you. Your thoughts become a confused tumult, darkness falls over your eyes and you collapse unconscious on the burning sand.";
    }
  ],
  time_left 0,
  found_in room06 room07 room12 room13 room14 room15 room16 room17 room18 room19 room20 room21,
has scenery;

!========================================
! Room 7: Desert
!========================================
Object room07 "Desert"
with
  description DESERT_DESCRIPTION,
  n_to
  [;
    if (player hasnt general)
      StopDaemon(desert);
    return room08;
  ],
  s_to room13,
  e_to room06,
  w_to room12,
  before
  [;
    Hint:
      if (player hasnt general)
        print_ret (string)THIRST_HINT, "north.";
      print_ret (string)DESERT_HINT;
  ],
has light;

!========================================
! Room 8: Small Oasis
!========================================
Object room08 "Small Oasis"
with
  description "This small oasis is a paradise of peace and tranquility, a true respite from the desert heat. An expanse of rich vegetation opens to the north and west, while the harsh desert awaits your return to the south.",
  n_to room09,
  s_to
  [;
    if (player hasnt general)
    {
      desert.time_left = 20;
      StartDaemon(desert);
    }
    return room07;
  ],
  w_to room11,
  before
  [;
    Hint:
      if (player hasnt general && room11 hasnt visited)
        print_ret (string)WELL_NEARBY;
      if (canteen in nothing)
        print_ret (string)FIND_CANTEEN;
      if (player hasnt general)
        print_ret (string)QUENCH_YOUR_THIRST;
  ],
has light;

!----------------------------------------
! Oasis (floating object)
!----------------------------------------
Object "oasis"
with
  article AN,
  name 'small' 'oasis',
  description "The oasis is a cool change from the heat of the desert, as it's shaded by date palms.",
  found_in room08 room09 room11,
has scenery;

!----------------------------------------
! Vegetation (floating object)
!----------------------------------------
Object "vegetation"
with
  article SOME,
  name 'vegetation' 'long' 'grass' 'grasses' 'low' 'bush' 'bushes' 'cluster' 'clusters' 'of' 'date' 'dates' 'palm' 'palms' 'tree' 'trees',
  description "The vegetation of the oasis consists of long grasses and low bushes growing beneath clusters of date palms.",
  before
  [;
    Climb, Search:
      "This is not the time or the place to start exploring the vegetation or climbing the trees.";
  ],
  found_in room08 room09 room11,
has scenery;

!----------------------------------------
! Desert (floating object)
!----------------------------------------
Object "desert"
with
  article THE,
  name 'desert' 'sand',
  description
  [;
    print "The desert sands await you to the ";
    if (self in room11)
      "east.";
    else
      "south.";
  ],
  found_in room08 room09 room11,
has scenery;

!========================================
! Room 9: Outside Tent in Oasis
!========================================
Object room09 "Outside Tent in Oasis"
with
  description "You're outside a tent in the oasis. Someone clearly thought that this was a good place to camp. If you're not mistaken, you can hear snoring coming from inside the tent, which is to the north. To the south, the rich vegetation of the oasis meets the sand of the desert.",
  n_to room10,
  s_to room08,
  in_to room10,
  before
  [;
    Hint:
      if (player hasnt general && room11 hasnt visited)
        print_ret (string)WELL_NEARBY;
      if (canteen in nothing)
        print_ret (string)FIND_CANTEEN;
      if (player hasnt general)
        print_ret (string)QUENCH_YOUR_THIRST;
    Listen:
      print "You can hear snoring coming from inside the tent.";
      if (room10 hasnt visited)
        print " Either that, or there's a wild animal in there.";
      "";
  ],
has light;

!----------------------------------------
! Tent (floating object)
!----------------------------------------
Object "tent"
with
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'tent' or 'traditional' or 'bedouin' or 'entrance' or 'bayt' or 'al-sha^r' or 'house' or 'of' or 'hair' or 'strips' or 'black' or 'goat')
    {
      i++;
      if (nw == 'bedouin' && TestScope(nomad))
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description "It's a traditional Bedouin tent, or bayt al-sha'r (meaning 'house of hair'). It appears to be made from strips of black goat hair woven into a fabric. This provides good insulation in the heat of the desert.",
  before
  [;
    Enter:
      if (self in room09)
        <<Go FAKE_N_OBJ>>;
    Exit:
      if (self in room10)
        <<Go FAKE_S_OBJ>>;
  ],
  found_in room09 room10,
has scenery;

!========================================
! Room 10: Inside Large Tent
!========================================
Object room10 "Inside Large Tent"
with
  description "You're inside a large tent where a nomad sleeps, sheltered from the heat and insects outside. The gloom of the tent is broken by a sliver of light that shines in through the entrance of the tent to the south.",
  s_to room09,
  out_to room09,
  before
  [;
    Hint:
      if (canteen in nothing)
        "Examine the nomad and do what is suggested.";
      if (player hasnt general && room11 hasnt visited)
        print_ret (string)WELL_NEARBY;
      if (player hasnt general)
        print_ret (string)QUENCH_YOUR_THIRST;
    Listen:
      "You can hear the nomad's snoring. Don't disturb him.";
  ],
has light;

!----------------------------------------
! Nomad
!----------------------------------------
Object nomad "nomad" room10
with
  name 'nomad' 'bedouin' 'arab' 'elderly' 'old' 'man',
  description
  [;
    print "He's an elderly man, most likely a Bedouin arab, dressed in a long flowing robe that insulates him from the heat. ";
    if (canteen in nothing)
      "While he's asleep, it might be a good idea to search him to make sure he doesn't have any concealed weapons.";
    print "You've already searched him, so let him rest in peace";
    if (canteen has moved)
      print ", lest he discovers that you've stolen his canteen";
    ".";
  ],
  life
  [;
    print "The nomad ";
    if (action == ##Attack or ##ThrowAt)
      "has done nothing to harm you, so leave him alone.";
    else
      "is asleep. Let him rest.";
  ],
  before
  [;
    Search:
      print "You carefully frisk the old man";
      if (canteen notin nothing)
        print_ret (string)DONT_FIND_ANYTHING_OF_INTEREST;
      move canteen to location;
      " and find a canteen.";
  ],
has animate;

!----------------------------------------
! Robe
!----------------------------------------
Object "robe" room10
with
  name 'long' 'flowing' 'robe' 'thobe' 'full-length' 'gown' 'clothes' 'clothing',
  description "It's a full-length gown, called a thobe, made from the wool of sheep, goats or camels.",
  before
  [;
    Take:
      "If you try to take the man's clothes, he's sure to wake up and then you'll have to deal with a mad Arab. No, it's best to leave him alone.";
  ],
has scenery;

!----------------------------------------
! Canteen
!----------------------------------------
Object canteen "canteen"
class OpenableContainer
with
  name 'canteen' 'modern' 'tin' 'leather' 'cover',
  description
  [;
    print "The Bedouin traditionally used a waterskin made of sheep or goat skin to hold water, but this is a modern tin canteen with a leather cover to help keep the water cool. ";
    <<Search self>>;
  ],
  before
  [;
    Drink:
      "You can drink water or drink from the canteen, but you can't drink the canteen itself. That wouldn't fit down your throat.";
    DrinkFrom:
      if (self hasnt open)
      {
        print (string)FIRST_OPENING_CANTEEN;
        give canteen open;
      }
      if (water notin self)
        print_ret (string)CANTEEN_IS_EMPTY;
      <<Drink water>>;
    Empty:
      if (self hasnt open)
      {
        print (string)FIRST_OPENING_CANTEEN;
        give canteen open;
      }
      if (water notin self)
        print_ret (string)CANTEEN_IS_EMPTY;
      remove water;
      print_ret (string)YOU_EMPTY_CANTEEN;
    Fill:
      if (bulk_water in location)
      {
        print "(with water)^";
        second = bulk_water;
      }
      <<FillWith self second>>;
    FillWith:
      if (self hasnt open)
      {
        print (string)FIRST_OPENING_CANTEEN;
        give canteen open;
      }
      if (water in self)
        "It's already full.";
      if (second == nothing)
        print_ret (string)NO_WATER_HERE;
      if (second ~= bulk_water)
        "You can't fill the canteen with ", (ThatOrThose)second, ".";
      if (second notin location)
        print_ret (string)NO_WATER_HERE;
      move water to self;
      print_ret (string)YOU_FILL_CANTEEN;
    Receive:
      if (noun ~= bulk_water)
        "The only thing you can put in the canteen is water.";
  ],
has container openable;

!========================================
! Room 11: Well in Oasis
!========================================
Object room11 "Well in Oasis"
with
  description "You're standing by a small well surrounded by the vegetation of an oasis. The vegetation thins out to the east to make way for the desert.",
  e_to room08,
  before
  [;
    Hint:
      if (canteen in nothing)
        print_ret (string)FIND_CANTEEN;
      if (player hasnt general && water notin canteen)
        "Fill the canteen.";
      if (player hasnt general)
        print_ret (string)QUENCH_YOUR_THIRST;
  ],
has light;

!----------------------------------------
! Well
!----------------------------------------
Object well "well" room11
with
  name 'small' 'well' 'circle' 'of' 'stones',
  description "The well consists of a circle of stones that appear to have been carefully laid to contain a natural spring. When you look into the well, you can see sparkling clear water that's just an arm's reach away.",
  before
  [;
    Search:
      <<Examine self>>;
  ],
has scenery;

!----------------------------------------
! Bulk water
!----------------------------------------
Object bulk_water "water" room11
with
  article SOME,
  name 'water' 'sparkling' 'clear' 'natural' 'spring',
  description "The sparkling clear spring water glistens in the sun.",
  before
  [;
    Drink:
      if (second ~= nothing && second ~= well)
        print_ret (string)YOU_CANT_DRINK_FROM, (ThatOrThose)second, ".";
      "You reach into the well, but the water trickles through your fingers before you can get it to your mouth. You'll need to collect it in a container before you can drink it.";
    Take:
      if (second == nothing && canteen in player)
      {
        print "(with the canteen)^";
        second = canteen;
      }
      if (second == nothing)
        "You need a container to put it in, something like a bucket or a canteen so that it doesn't splash all over the place.";
      if (second ~= canteen)
        "You can't put the water in ", (ThatOrThose)second, ".";
      if (canteen hasnt open)
      {
        print (string)FIRST_OPENING_CANTEEN;
        give canteen open;
      }
      if (water in canteen)
        "The canteen is already full.";
      move water to canteen;
      print_ret (string)YOU_FILL_CANTEEN;
    ],
has scenery;

!----------------------------------------
! Water
!----------------------------------------
Object water "water"
with
  article SOME,
  name 'water',
  description "It's the life-giving water that you got from the well in the oasis.",
  before
  [;
    Drink:
      if (second ~= nothing && second ~= canteen)
        print_ret (string)YOU_CANT_DRINK_FROM, (ThatOrThose)second, ".";
      if (player has general)
        "You take another sip of water and save the rest for later.";
      give player general;
      StopDaemon(desert);
      remove self;
      "You drink from the canteen until all the water is gone. Ahh, you feel so refreshed.";
    Empty:
      remove water;
      print_ret (string)YOU_EMPTY_CANTEEN;
    Take:
      "If you want to take the water out of the canteen, just empty it.";
  ],
has;

