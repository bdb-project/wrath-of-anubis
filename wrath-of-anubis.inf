!========================================
! Room 14: Desert
!========================================
Object room14 "Desert"
with
  description DESERT_DESCRIPTION,
  n_to room06,
  s_to room13,
  e_to room15,
  w_to room13,
  before
  [;
    Hint:
      if (player hasnt general)
        print_ret (string)THIRST_HINT, "north or west.";
      if (camel hasnt general)
        "Examine the camel and do what is suggested.";
      if (meat has scenery)
      {
        print "Recall what you were told when you shot the camel. You can do the same";
        if (knife notin player)
          print ", but you'll need a knife";
        ".";
      }
  ],
has light;

!----------------------------------------
! Camel
!----------------------------------------
Object camel "camel" room14
with
  name 'camel' 'rump' 'hide',
  short_name
  [;
    if (self has general)
      print "dead ";
    rfalse;
  ],
  description
  [;
    print "The camel is lying on the sand. ";
    if (self hasnt general)
      print_ret (string)POOR_THING_HAS_BROKEN_LEG, " The humane thing to do would be to put it out of its misery.";
    print "It's now dead, since you shot it to put it out of its misery.";
    if (meat hasnt scenery)
      print " It's also got a huge chunk cut out of its rump.";
    "";
  ],
  life
  [;
    if (self has general && action ~= ##Attack)
      "It's dead.";
    Attack:
      if (self has general)
        "It's already dead.";
      if (second ~= knife)
        "The poor camel is in enough pain without you attacking it. If you're trying to kill it, try to find a humane way to do it.";
      print_ret (string)CUTTING_UP_LIVE_CAMEL_IS_CRUEL;
  ],
  before
  [;
    Cut:
      if (second == nothing && knife in player)
      {
        print "(with the knife)^";
        second = knife;
      }
      if (second == nothing)
        "You don't have anything sharp enough to cut the camel's tough hide.";
      if (second == chisel)
        "That's a good idea, but the blade of the chisel is too narrow to cut up a camel. It's also quite blunt from chopping into dirt and rocks.";
      if (second ~= knife)
        "You can't cut the camel with ", (ThatOrThose)second, ".";
      if (self hasnt general)
        print_ret (string)CUTTING_UP_LIVE_CAMEL_IS_CRUEL;
      if (meat hasnt scenery)
        "You've already cut a huge chunk of meat out of the camel's rump. Blowflies are now buzzing around the raw flesh, so it doesn't look healthy to cut any more. You never know what germs you might pick up.";
      give meat ~scenery;
      "You take the knife and cut a huge chunk of flesh from the camel's rump. This will be good to keep in reserve in case you need emergency rations.";
    Eat:
      "Do you expect to eat a whole camel in one sitting? Maybe you could just cut a piece out of it.";
    Enter:
      print "Have you examined it? ";
      if (self hasnt general)
        print_ret (string)POOR_THING_HAS_BROKEN_LEG;
      else
        "It's dead.";
    Shoot:
      if (second == nothing && pistol in player)
      {
        print "(with the pistol)^";
        second = pistol;
      }
      if (second == nothing)
        print_ret (string)YOU_DONT_HAVE_FIREARM;
      if (second ~= pistol)
        print_ret (string)CANT_SHOOT_ANYTHING_WITH, (ThatOrThose)second, ".";
      if (self has general)
        "The camel is already dead, so don't waste your ammo.";
      give self general;
      move meat to location;
      "You point the pistol at the camel's head and slowly pull the trigger. BLAM! You put the poor creature out of its misery, but that doesn't make you feel any better. You immediately recall how the nomadic people of this region use their dead camels for meat. Maybe you could do the same.";
    Touch:
      "Its hide is very tough.";
    Take:
      "Do you expect to just sling a camel over your shoulder? In your dreams!";
  ],
has animate neuter;

!----------------------------------------
! Broken leg
!----------------------------------------
Object "broken leg" room14
with
  name 'broken' 'leg',
  description
  [;
    print "Camels are like horses. If they have a broken leg, there's really nothing much you can do, except to put the poor creature out of its misery";
    if (camel has general)
      print ", which you've already done";
    ". It makes you glad you're not a camel. It's also a reminder that you need to be extremely careful in the desert.";
  ],
has scenery;

!----------------------------------------
! Camel meat
!----------------------------------------
Object meat "camel meat"
with
  article SOME,
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'camel' or 'meat' or 'chunk' or 'of' or 'flesh')
    {
      i++;
      if (nw == 'camel' && TestScope(camel))
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description "It's the chunk of meat that you cut from the dead camel.",
  before
  [;
    if (self has scenery && action ~= ##Cut)
    {
      PrintMsg(MSG_PARSER_NOSUCHTHING);
      rtrue;
    }
    Cut:
      <<Cut camel second>>;
    Eat:
      "It's raw. Either cook it first or save it for an emergency.";
  ],
has scenery;

